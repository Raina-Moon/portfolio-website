---
import PortfolioLayout from "@/layouts/PortfolioLayout.astro";
import TroubleshootingEditDetailPage from "@/react-pages/TroubleshootingEditDetailPage";

export const prerender = false;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/troubleshooting/edit");
}
---

<PortfolioLayout
  title="Troubleshooting Edit | Raina Moon"
  description="Private troubleshooting editor."
  noindex={true}
>
  <TroubleshootingEditDetailPage id={id} client:load />
</PortfolioLayout>
