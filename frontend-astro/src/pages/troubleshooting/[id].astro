---
import PortfolioLayout from "@/layouts/PortfolioLayout.astro";
import TroubleshootingDetailPage from "@/react-pages/TroubleshootingDetailPage";

export const prerender = false;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/troubleshooting");
}
---

<PortfolioLayout title="Troubleshooting Detail | Raina Moon">
  <TroubleshootingDetailPage id={id} client:load />
</PortfolioLayout>
